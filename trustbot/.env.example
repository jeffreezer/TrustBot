# TrustBot configuration — copy to .env for local (non-docker) dev.
# PRINCIPLE: all config comes from environment variables. Never hard-code these.
# This is what makes local -> GCP -> AWS a config change, not a rewrite.
#
# NOTE: the trustbot / trustbot123 values below are LOCAL-ONLY throwaway demo
# credentials — safe to keep in this template because .env itself is gitignored.
# Real deployments inject secrets from the environment / a secret manager (GCP
# Secret Manager, AWS Secrets Manager) and must never reuse these.

APP_ENV=local

# --- Database (Postgres + pgvector) ---
# Local non-docker default. In docker-compose this is overridden to host "postgres".
# On GCP use Cloud SQL; on AWS use RDS — same driver, just a different URL.
DATABASE_URL=postgresql+psycopg://trustbot:trustbot@localhost:5432/trustbot

# --- API ---
CORS_ORIGINS=http://localhost:3000

# --- Frontend (docker compose only) ---
# Host port the web UI is published on. Default 3000 keeps the documented
# http://localhost:3000 experience; override (e.g. WEB_PORT=3001) if something
# else already occupies 3000. Container-internal port stays 3000.
WEB_PORT=3000

# --- Object storage (S3-compatible) ---
# STORAGE_BACKEND: "local" (filesystem) or "s3" (MinIO locally, GCS or S3 in cloud).
STORAGE_BACKEND=local
LOCAL_STORAGE_DIR=./_storage
S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET=trustbot-evidence
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=trustbot
S3_SECRET_ACCESS_KEY=trustbot123
# Optional S3 server-side encryption (e.g. "AES256" or "aws:kms"). Empty by
# default so the local MinIO demo isn't broken; turn on in cloud.
S3_SSE=

# --- Seed data (synthetic Northwind demo company) ---
# Mounted read-only into the api container in docker-compose; override for local runs.
SEED_DATA_DIR=/seed/northwind_ai

# --- Model provider ---
# Access goes through one provider-abstraction module. Swap provider without touching app code.
MODEL_PROVIDER=
MODEL_API_KEY=
MODEL_BASE_URL=
EMBEDDING_MODEL=BAAI/bge-m3
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# --- Embedding + ingestion (Phase 2) ---
# EMBEDDING_PROVIDER: which backend the provider abstraction uses.
#   local – BGE-M3 on CPU (default; baked into the image at build time)
#   hash  – deterministic, dependency-free fake (tests / offline CI; no real semantics)
#   api   – OpenAI-compatible /v1/embeddings using MODEL_BASE_URL + MODEL_API_KEY
EMBEDDING_PROVIDER=local
# Character-based chunking (token-free). CHUNK_OVERLAP must be >= 0 and < CHUNK_SIZE.
CHUNK_SIZE=1200
CHUNK_OVERLAP=200
# Hard cap on a single ingested document (boundary validation), in bytes.
MAX_INGEST_BYTES=10485760
